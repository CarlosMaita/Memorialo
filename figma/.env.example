# Backend routing mode for incremental migration
# supabase: all endpoints against Supabase function server
# laravel: routes /health, /auth, /users, /providers, /services to Laravel; rest keep using Supabase
VITE_BACKEND_MODE=supabase

# Supabase function server base URL (without trailing slash)
VITE_API_BASE_URL=https://lpoybvmalhxlomsrssgm.supabase.co/functions/v1/make-server-5d78aefb

# Laravel API base URL (without trailing slash)
VITE_LARAVEL_API_BASE_URL=http://127.0.0.1:8000/api
